# Generated by Cargo
# will have compiled files and executables
debug
target

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Generated by cargo mutants
# Contains mutation testing data
**/mutants.out*/

# Cargo.lock is intentionally NOT ignored: Ymir is an application, so the
# committed lockfile gives every machine and contributor identical deps.

# Local terrain output and test renders
/out
/outputs
*.tmp

# Editor and IDE
.idea/
.vscode/
*.iml

# OS cruft
.DS_Store
Thumbs.db

# Claude Code: transient agent worktrees and local settings (settings.json is shared)
.claude/worktrees/
.claude/settings.local.json
